#:culture{:id "ken.dish.nyama-choma", :name "Nyama choma", :country "KEN", :kind :dish, :summary "Grilled or barbecued goat or cattle meat, considered the national dish of Kenya and Tanzania.", :url "https://en.wikipedia.org/wiki/Nyama_choma", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "ken.dish.ugali", :name "Ugali", :country "KEN", :kind :dish, :summary "Corn meal made from maize flour, a staple starch eaten across East Africa including Kenya, where it is typically served with vegetables or meat.", :url "https://en.wikipedia.org/wiki/Ugali", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
