#:culture{:id "ken.product.kenyan-tea", :name "Kenyan tea", :country "KEN", :kind :product, :summary "Tea is a major Kenyan export crop; in 2018 Kenya was the world's largest exporter and producer of black tea, and it ranks third globally in tea exports after China and India.", :url "https://en.wikipedia.org/wiki/Tea_production_in_Kenya", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "ken.product.kenyan-coffee", :name "Kenyan coffee", :country "KEN", :kind :product, :summary "Kenya produces primarily Arabica coffee of the 'Colombia mild' classification; high-grade Kenyan coffee is among the most sought-after in the world for its intense flavor, full body and pleasant aroma.", :url "https://en.wikipedia.org/wiki/Coffee_production_in_Kenya", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
