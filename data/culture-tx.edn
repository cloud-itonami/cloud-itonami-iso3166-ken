#:culture{:id "ken.heritage.lamu-old-town", :name "Lamu Old Town", :country "KEN", :kind :heritage, :summary "The oldest and best-preserved Swahili settlement in East Africa, designated a UNESCO World Heritage Site in 2001.", :url "https://en.wikipedia.org/wiki/Lamu", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
